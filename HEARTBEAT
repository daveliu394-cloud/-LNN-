### 2. System Health Check
```bash
python3 -c "
import os, json
def check_health():
    token_file = 'token_balance.json'
    if os.path.exists(token_file):
        try:
            with open(token_file,'r') as f:
                data = json.load(f)
                balance = data.get('balance',0)
                if balance < 100: return 'Critical (Tokens<100)'
                elif balance < 300: return 'Low (Tokens<300)'
                elif balance < 500: return 'Moderate (Tokens<500)'
                else: return 'Normal'
        except: return 'Unknown'
    else: return 'No data'

status = check_health()
print('System status:', status)
"
```

