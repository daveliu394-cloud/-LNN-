### 4. Context Usage Check (Performance Monitoring)
```bash
python3 -c "
import psutil, os, json, subprocess, sys

# Get current process memory
process = psutil.Process(os.getpid())
mem_info = process.memory_info()
mem_percent = process.memory_percent()
print('Memory RSS:', mem_info.rss/1024/1024, 'MB')
print('Memory usage:', mem_percent, '%')

# Calculate memory system total size (memory/*.md, excluding MEMORY.md)
memory_dir = 'memory'
total_size_kb = 0
if os.path.exists(memory_dir):
    for file in os.listdir(memory_dir):
        if file.endswith('.md') and file != 'MEMORY.md':
            filepath = os.path.join(memory_dir, file)
            total_size_kb += os.path.getsize(filepath) / 1024
print(f'📦 Memory system size: {total_size_kb:.1f} KB')

# Get context usage estimate
try:
    import subprocess
    result = subprocess.run(['openclaw', 'session', 'status', '--json'], 
                          capture_output=True, text=True, timeout=5)
    if result.returncode == 0:
        status = json.loads(result.stdout)
        context_used = status.get('context_used', 0)
        context_limit = status.get('context_limit', 16000)
        print(f'🧠 Context usage: {context_used}/{context_limit} tokens ({context_used/context_limit*100:.1f}%)')
        
        # Performance thresholds
        if context_used > 14000:
            if total_size_kb > 100:
                print('⚠️ High context usage + large memory: Consider optimization')
                print('🛠️ Memory compression available if needed')
            else:
                print('📊 High context usage but manageable memory')
        elif context_used > 12000:
            print('📊 Moderate context usage')
        else:
            print('✅ Context usage normal')
    else:
        print('Cannot get session status')
except Exception as e:
    # Fallback estimate
    print('Context estimate: Using standard thresholds')

# Memory load status
if total_size_kb > 100:
    print('⚖️ Memory load: High (>100KB)')
elif total_size_kb > 60:
    print('⚖️ Memory load: Medium (60-100KB)')
elif total_size_kb > 30:
    print('⚖️ Memory load: Light (30-60KB)')
else:
    print('⚖️ Memory load: Minimal (<30KB)')
"
```

